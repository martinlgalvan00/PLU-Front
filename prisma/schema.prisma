generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin_maximal
  admin_plu_arg
  operador_plu_arg
  viewer_plu_usa
}

enum AthleteStatus {
  pre_registrado
  registrado
  afiliado_activo
  afiliado_vencido
  bloqueado
}

enum MembershipStatus {
  pendiente_pago
  activa
  vencida
  cancelada
  reembolsada
}

enum RegistrationStatus {
  borrador
  pendiente_pago
  pagada
  confirmada
  observada
  cancelada
}

enum PaymentStatus {
  creado
  pendiente
  aprobado
  rechazado
  cancelado
  reembolsado
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(operador_plu_arg)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  auditLogs    AuditLog[]
}

model Athlete {
  id              String        @id @default(cuid())
  fullName        String
  documentId      String        @unique
  birthDate       DateTime
  email           String        @unique
  phone           String
  country         String        @default("Argentina")
  province        String
  city            String
  gym             String
  sex             String
  division        String
  category        String
  estimatedWeight String?
  status          AthleteStatus @default(pre_registrado)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  memberships     Membership[]
  registrations   EventRegistration[]
  payments        Payment[]
}

model Membership {
  id             String           @id @default(cuid())
  athleteId      String
  athlete        Athlete          @relation(fields: [athleteId], references: [id])
  year           Int
  status         MembershipStatus @default(pendiente_pago)
  startDate      DateTime
  expirationDate DateTime
  memberCode     String           @unique
  paymentStatus  String?
  mercadoPagoRef String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Event {
  id           String              @id @default(cuid())
  slug         String              @unique
  title        String
  venue        String
  location     String
  eventDate    DateTime
  capacity     Int?
  status       String              @default("draft")
  requiresMembership Boolean       @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  registrations EventRegistration[]
  results      LiftingResult[]
}

model EventRegistration {
  id            String             @id @default(cuid())
  athleteId     String
  athlete       Athlete            @relation(fields: [athleteId], references: [id])
  eventId       String
  event         Event              @relation(fields: [eventId], references: [id])
  category      String
  division      String
  bodyweight    String?
  status        RegistrationStatus @default(borrador)
  paymentStatus String?
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model PaymentOrder {
  id              String    @id @default(cuid())
  externalRef     String?   @unique
  preferenceId    String?
  amount          Int
  currency        String    @default("ARS")
  concept         String
  status          PaymentStatus @default(creado)
  method          String
  athleteId       String?
  metadata        Json?
  idempotencyKey  String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  payments        Payment[]
}

model Payment {
  id             String       @id @default(cuid())
  orderId        String
  order          PaymentOrder @relation(fields: [orderId], references: [id])
  athleteId      String
  athlete        Athlete      @relation(fields: [athleteId], references: [id])
  amount         Int
  method         String
  status         PaymentStatus @default(creado)
  reference      String?
  mercadoPagoId  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model LiftingResult {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id])
  athleteName  String
  division     String?
  category     String?
  bodyweightKg Float?
  squat1Kg     Float?
  bench1Kg     Float?
  deadlift1Kg  Float?
  totalKg      Float?
  place        Int?
  rawData      Json?
  source       String   @default("liftingcast")
  createdAt    DateTime @default(now())
}

model Export {
  id        String   @id @default(cuid())
  type      String
  format    String
  filters   Json?
  filePath  String?
  createdBy String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  metadata   Json?
  createdAt  DateTime @default(now())
}

model EmailLog {
  id         String   @id @default(cuid())
  type       String
  to         String
  templateId String?
  status     String
  params     Json?
  error      String?
  createdAt  DateTime @default(now())
}
